# ==========================================
# 星驿支付签名验签中转服务配置文件
# ==========================================
#
# 说明：
# 本配置文件包含签名验签中转服务所需的所有配置项
# 请根据实际情况修改配置值
#
# 注意：
# 1. RSA_PUBLIC_KEY 是必须配置的项，由星驿支付官方提供
# 2. 其他配置项都有默认值，可根据需要修改
# 3. 请勿将此文件提交到版本控制系统，以免泄露敏感信息

# ------------------------------------------
# RSA公钥配置（必须配置）
# ------------------------------------------
#
# RSA公钥字符串，由星驿支付官方提供
# 支持两种格式：
#
# 格式1：纯Base64内容（推荐，更简洁）
# 程序会自动添加PEM头部和尾部标记，并按64字符换行
# RSA_PUBLIC_KEY=MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
#
# 格式2：完整PEM格式（标准格式）
# RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
# MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
# -----END PUBLIC KEY-----"
#
# 注意：
# 1. 实际使用时请替换为星驿支付官方提供的真实公钥
# 2. 公钥必须是有效的Base64编码字符串
# 3. 程序会自动处理格式转换，无需手动换行
RSA_PUBLIC_KEY=

# ------------------------------------------
# 监控密码配置（必须配置）
# ------------------------------------------
#
# 监控页面访问密码
# 用于保护监控页面，防止未授权访问
# 请设置一个强密码，确保安全性
#
# 示例：MONITOR_PASSWORD=your_secure_password_here
MONITOR_PASSWORD=

# ------------------------------------------
# 服务器配置（可选，有默认值）
# ------------------------------------------

# 服务监听地址
# 默认值：0.0.0.0（监听所有网络接口）
# 如需只监听本地，可设置为：127.0.0.1
SERVER_HOST=0.0.0.0

# 服务监听端口
# 默认值：8080
# 如需使用其他端口，请修改此值
SERVER_PORT=8080